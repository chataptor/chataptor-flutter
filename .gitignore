# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# VS Code
.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/

# Android local SDK paths (machine-specific, never commit)
**/android/local.properties
**/android/.gradle/
**/android/captures/
**/android/key.properties
**/*.jks
**/*.keystore

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio build artifacts
/android/app/debug
/android/app/profile
/android/app/release

# Coverage
coverage/
.coverage/
lcov.info

# pubspec.lock is gitignored for library packages (not apps).
# See https://dart.dev/tools/pub/private-files#pubspec-lock
# Keep pubspec.lock for example apps (override per-directory below).
pubspec.lock
!example*/pubspec.lock
!examples/**/pubspec.lock

# Melos
.melos_tool/

# OS
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Environment files (never commit secrets)
.env
.env.local
.env.*.local

# Local run scripts with real credentials (use run_local.*.example as template)
run_local.sh
run_local.ps1
run_local.bat

# Git worktrees
.worktrees/

# Local sandbox app for integration testing (not published)
examples/sandbox/

# Local scratchpad for ad-hoc artifacts (screenshots, notes)
.tmp/

# Claude Code local settings (machine-specific permissions)
.claude/settings.local.json
